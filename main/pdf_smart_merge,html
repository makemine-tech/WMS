<script type="module">
import * as pdfjsLib from 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.0.379/pdf.min.mjs';
pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.0.379/pdf.worker.min.mjs';
window._pdfjsLib = pdfjsLib;
</script>
<script>
const files = [];
let groups = [];

// ── Drag & Drop ──
const dropZone = document.getElementById('dropZone');
dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('over'); });
dropZone.addEventListener('dragleave', e => { if (!dropZone.contains(e.relatedTarget)) dropZone.classList.remove('over'); });
dropZone.addEventListener('drop', e => { e.preventDefault(); dropZone.classList.remove('over'); addFiles(e.dataTransfer.files); });
document.getElementById('fileInput').addEventListener('change', e => { addFiles(e.target.files); e.target.value = ''; });

function addMoreFiles() { document.getElementById('fileInput').click(); }

function toggleApiPanel() {
  const panel = document.getElementById('apiPanel');
  const btn = document.getElementById('apiToggle');
  const isOpen = panel.classList.toggle('open');
  btn.classList.toggle('active', isOpen);
}

// ── File Add ──
async function addFiles(fileList) {
  let added = 0;
  for (const f of fileList) {
    if (f.type === 'application/pdf' && !files.find(x => x.name === f.name && x.size === f.size)) {
      files.push(f); added++;
    }
  }
  if (added) renderThumbs();
}

// ── Render Thumbnails ──
async function renderThumbs() {
  const grid = document.getElementById('thumbGrid');
  grid.innerHTML = '';
  document.getElementById('fileCount').textContent = files.length + '개';
  document.getElementById('uploadedSection').style.display = files.length ? '' : 'none';

  for (let i = 0; i < files.length; i++) {
    const f = files[i];
    const card = document.createElement('div');
    card.className = 'thumb-card';

    const preview = document.createElement('div');
    preview.className = 'thumb-preview';

    const nameEl = document.createElement('div');
    nameEl.className = 'thumb-name';
    nameEl.title = f.name;
    nameEl.textContent = f.name;

    const rm = document.createElement('div');
    rm.className = 'thumb-remove';
    rm.innerHTML = '&times;';
    rm.onclick = ev => { ev.stopPropagation(); files.splice(i, 1); renderThumbs(); };

    card.appendChild(preview);
    card.appendChild(nameEl);
    card.appendChild(rm);
    grid.appendChild(card);

    // Async render
    (async (file, previewEl) => {
      try {
        const lib = window._pdfjsLib;
        if (!lib) { await waitForPdfJs(); }
        const ab = await file.arrayBuffer();
        const pdf = await window._pdfjsLib.getDocument({ data: ab }).promise;
        const page = await pdf.getPage(1);
        const viewport = page.getViewport({ scale: 1.5 });
        const canvas = document.createElement('canvas');
        canvas.width = viewport.width;
        canvas.height = viewport.height;
        await page.render({ canvasContext: canvas.getContext('2d'), viewport }).promise;
        previewEl.appendChild(canvas);
        file._thumb = canvas.toDataURL('image/jpeg', 0.55);
        file._pageSize = { w: viewport.width, h: viewport.height };
        file._isLandscape = viewport.width > viewport.height;
      } catch(e) {
        previewEl.innerHTML = `<div class="thumb-preview-empty"><svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14,2 14,8 20,8"/></svg><span>PDF</span></div>`;
      }
    })(f, preview);
  }
}

function waitForPdfJs() {
  return new Promise(res => {
    const t = setInterval(() => { if (window._pdfjsLib) { clearInterval(t); res(); } }, 100);
    setTimeout(() => { clearInterval(t); res(); }, 5000);
  });
}

// ── Analyze ──
async function analyze() {
  if (!files.length) return;
  const btn = document.getElementById('analyzeBtn');
  btn.disabled = true;

  document.getElementById('resultSection').style.display = '';
  document.getElementById('groupsContainer').innerHTML = '';
  document.getElementById('downloadSection').style.display = 'none';

  setStatus('파일 분석 중...', 'active', 5);

  // Wait for thumbs
  await new Promise(r => setTimeout(r, 600));

  const apiKey = document.getElementById('apiKeyInput').value.trim();
  if (apiKey) {
    await analyzeWithAI(apiKey);
  } else {
    setStatus('파일명 기준으로 분류합니다. (AI 기능: 상단 AI 설정에서 API Key 입력)', 'active', 20);
    await new Promise(r => setTimeout(r, 800));
    fallbackGroup();
    setStatus(`완료 — ${groups.length}개 그룹으로 분류됨`, 'done', 100);
  }

  renderGroups();
  document.getElementById('downloadSection').style.display = '';
  updateDownloadSub();
  btn.disabled = false;
  setTimeout(() => document.getElementById('progressTrack').style.display = 'none', 800);
}

async function analyzeWithAI(apiKey) {
  setStatus('AI가 문서 레이아웃 분석 중...', 'active', 30);

  const content = [];
  const thumbFiles = files.filter(f => f._thumb);

  for (const f of thumbFiles) {
    content.push({ type: 'image', source: { type: 'base64', media_type: 'image/jpeg', data: f._thumb.split(',')[1] } });
    content.push({ type: 'text', text: `위 이미지 = 파일명: "${f.name}", 방향: ${f._isLandscape ? '가로' : '세로'}` });
  }

  content.push({ type: 'text', text: `
전체 파일 목록 (인덱스: 파일명):
${files.map((f, i) => `${i}: ${f.name}`).join('\n')}

위 파일들을 문서 유형/레이아웃이 같은 것끼리 그룹화하세요.
- 이미지 레이아웃 유사성 우선 판단
- 파일명 키워드도 참고 (예: 송장, 거래명세, 라벨, 적재)
- 각 그룹 내 indices는 파일명 오름차순 정렬
- 그룹명은 한국어로 짧게 (예: "거래명세표", "배송라벨", "적재리스트")
- JSON만 반환, 다른 텍스트 없이:
{"groups":[{"name":"그룹명","indices":[0,2,4]},{"name":"그룹명2","indices":[1,3,5]}]}`
  });

  try {
    setStatus('AI 응답 대기 중...', 'active', 55);
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'x-api-key': apiKey, 'anthropic-version': '2023-06-01' },
      body: JSON.stringify({ model: 'claude-opus-4-5', max_tokens: 1000, messages: [{ role: 'user', content }] })
    });
    if (!res.ok) throw new Error('API 오류: ' + res.status);
    const data = await res.json();
    const text = data.content?.map(x => x.text || '').join('');
    const clean = text.replace(/```json|```/g, '').trim();
    const parsed = JSON.parse(clean);
    groups = parsed.groups;
    setStatus(`AI 분류 완료 — ${groups.length}개 그룹`, 'done', 100);
  } catch(e) {
    setStatus('AI 분류 실패, 파일명 기준으로 대체 분류합니다.', 'active', 80);
    await new Promise(r => setTimeout(r, 600));
    fallbackGroup();
    setStatus(`분류 완료 — ${groups.length}개 그룹`, 'done', 100);
  }
}

function fallbackGroup() {
  // 파일명에서 공통 키워드 추출로 그룹핑
  const keywordMap = {};
  const keywords = ['송장', '거래명세', '라벨', '적재', '명세', '인보이스', 'invoice', 'label', 'packing', 'delivery'];

  files.forEach((f, i) => {
    const lower = f.name.toLowerCase();
    let matched = null;
    for (const kw of keywords) {
      if (lower.includes(kw.toLowerCase())) { matched = kw; break; }
    }
    const key = matched || (f._isLandscape ? '_landscape' : '_portrait');
    if (!keywordMap[key]) keywordMap[key] = [];
    keywordMap[key].push(i);
  });

  const nameMap = {
    '송장': '송장', '거래명세': '거래명세표', '라벨': '배송라벨',
    '적재': '적재리스트', '명세': '명세서', '인보이스': '인보이스',
    'invoice': '인보이스', 'label': '라벨', 'packing': '패킹리스트',
    'delivery': '배송서류', '_landscape': '가로형 문서', '_portrait': '세로형 문서'
  };

  groups = Object.entries(keywordMap).map(([key, indices]) => ({
    name: nameMap[key] || key,
    indices: indices.sort((a, b) => files[a].name.localeCompare(files[b].name))
  }));

  if (!groups.length) groups = [{ name: '전체 파일', indices: files.map((_, i) => i) }];
}

// ── Render Groups ──
function renderGroups() {
  const container = document.getElementById('groupsContainer');
  container.innerHTML = '';

  groups.forEach((g, gi) => {
    const block = document.createElement('div');
    block.className = 'group-block';

    const hdr = document.createElement('div');
    hdr.className = 'group-header';
    hdr.onclick = () => {
      body.classList.toggle('collapsed');
      chev.classList.toggle('open');
    };

    const idx = document.createElement('div');
    idx.className = `group-index gi-${gi % 6}`;
    idx.textContent = gi + 1;

    const name = document.createElement('div');
    name.className = 'group-name';
    name.textContent = g.name;

    const meta = document.createElement('div');
    meta.className = 'group-meta';
    meta.textContent = `${g.indices.length}개`;

    const chev = document.createElement('div');
    chev.className = 'group-chevron open';
    chev.innerHTML = `<svg viewBox="0 0 24 24"><polyline points="18,15 12,9 6,15"/></svg>`;

    hdr.appendChild(idx);
    hdr.appendChild(name);
    hdr.appendChild(meta);
    hdr.appendChild(chev);

    const body = document.createElement('div');
    body.className = 'group-body';

    g.indices.forEach(fileIdx => {
      const f = files[fileIdx];
      if (!f) return;
      const card = document.createElement('div');
      card.className = 'thumb-card';

      const preview = document.createElement('div');
      preview.className = 'thumb-preview';

      if (f._thumb) {
        const img = document.createElement('img');
        img.src = f._thumb;
        preview.appendChild(img);
      } else {
        preview.innerHTML = `<div class="thumb-preview-empty"><svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14,2 14,8 20,8"/></svg><span>PDF</span></div>`;
      }

      const nm = document.createElement('div');
      nm.className = 'thumb-name';
      nm.textContent = f.name;
      nm.title = f.name;

      card.appendChild(preview);
      card.appendChild(nm);
      body.appendChild(card);
    });

    block.appendChild(hdr);
    block.appendChild(body);
    container.appendChild(block);
  });
}

// ── Merge & Download ──
async function mergeAndDownload() {
  const btn = document.getElementById('mergeBtn');
  btn.disabled = true;
  document.getElementById('progressTrack').style.display = '';

  const total = groups.reduce((s, g) => s + g.indices.length, 0);
  let done = 0;
  setStatus('PDF 병합 중...', 'active', 5);

  try {
    const { PDFDocument } = PDFLib;
    const merged = await PDFDocument.create();

    for (const g of groups) {
      for (const idx of g.indices) {
        const f = files[idx];
        const ab = await f.arrayBuffer();
        const src = await PDFDocument.load(ab, { ignoreEncryption: true });
        const pages = await merged.copyPages(src, src.getPageIndices());
        pages.forEach(p => merged.addPage(p));
        done++;
        setStatus(`병합 중... (${done} / ${total})`, 'active', 5 + (done / total * 88));
      }
    }

    setStatus('저장 중...', 'active', 97);
    const bytes = await merged.save();
    const blob = new Blob([bytes], { type: 'application/pdf' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'merged_' + new Date().toISOString().slice(0,10) + '.pdf';
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);

    setStatus(`완료 — ${total}개 파일 · ${(bytes.length / 1024 / 1024).toFixed(1)}MB 병합됨`, 'done', 100);
    setTimeout(() => document.getElementById('progressTrack').style.display = 'none', 1200);
  } catch(e) {
    setStatus('병합 실패: ' + e.message, 'error');
  }
  btn.disabled = false;
}

// ── Helpers ──
function setStatus(msg, state, progress) {
  const dot = document.getElementById('statusDot');
  const text = document.getElementById('statusText');
  const prog = document.getElementById('statusProgress');
  const track = document.getElementById('progressTrack');
  const fill = document.getElementById('progressFill');

  dot.className = 'status-dot' + (state ? ' ' + state : '');
  text.textContent = msg;

  if (progress !== undefined) {
    track.style.display = '';
    fill.style.width = progress + '%';
    prog.textContent = Math.round(progress) + '%';
  } else {
    prog.textContent = '';
  }
}

function updateDownloadSub() {
  const total = groups.reduce((s, g) => s + g.indices.length, 0);
  document.getElementById('downloadSub').textContent =
    `${groups.length}개 그룹 · 총 ${total}개 파일 · 그룹 순서대로 병합됩니다`;
}

function clearAll() {
  files.length = 0;
  groups = [];
  document.getElementById('thumbGrid').innerHTML = '';
  document.getElementById('uploadedSection').style.display = 'none';
  document.getElementById('resultSection').style.display = 'none';
  document.getElementById('fileInput').value = '';
}
</script>
