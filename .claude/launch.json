{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Firebase Hosting (local)",
      "runtimeExecutable": "firebase",
      "runtimeArgs": ["serve", "--only", "hosting", "--port", "5000"],
      "port": 5000
    },
    {
      "name": "Firebase Emulators (full)",
      "runtimeExecutable": "firebase",
      "runtimeArgs": ["emulators:start"],
      "port": 5000
    },
    {
      "name": "Static Server (main/)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["--yes", "serve", "main", "-l", "8000"],
      "port": 8000
    }
  ]
}
