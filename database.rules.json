{
  "rules": {
    "warehouses": {
      "$wid": {
        ".read": "auth != null && (root.child('superadmins/'+auth.uid).exists() || root.child('userWarehouse/'+auth.uid).val() === $wid)",
        ".write": "auth != null && (root.child('superadmins/'+auth.uid).exists() || root.child('userWarehouse/'+auth.uid).val() === $wid)",
        "members": {
          "$uid": {
            ".write": "auth != null && auth.uid === $uid"
          }
        }
      }
    },
    "warehouseIndex": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "userWarehouse": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "notice": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "superadmins": {
      ".read": "auth != null",
      ".write": false
    }
  }
}