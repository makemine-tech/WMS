{
  "rules": {
    "warehouses": {
      "$wid": {
        ".read": "auth != null && (root.child('superadmins/'+auth.uid).exists() || root.child('userWarehouse/'+auth.uid).val() === $wid)",
        ".write": "auth != null && (root.child('superadmins/'+auth.uid).exists() || root.child('userWarehouse/'+auth.uid).val() === $wid)",
        "members": {
          "$uid": {
            ".write": "auth != null && auth.uid === $uid"
          }
        }
      }
    },
    "warehouseIndex": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "userWarehouse": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "userGroup": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && (auth.uid === $uid || root.child('superadmins/'+auth.uid).exists())"
      }
    },
    "groups": {
      ".read": "auth != null && root.child('superadmins/'+auth.uid).exists()",
      "$gid": {
        ".read": "auth != null && (root.child('superadmins/'+auth.uid).exists() || root.child('userGroup/'+auth.uid).val() === $gid)",
        ".write": "auth != null && root.child('superadmins/'+auth.uid).exists()"
      }
    },
    "inviteCodes": {
      ".read": "auth != null",
      "$code": {
        ".write": "auth != null"
      }
    },
    "notices": {
      "$gid": {
        ".read": "auth != null && (root.child('superadmins/'+auth.uid).exists() || root.child('userGroup/'+auth.uid).val() === $gid)",
        ".write": "auth != null && (root.child('superadmins/'+auth.uid).exists() || root.child('userGroup/'+auth.uid).val() === $gid)"
      }
    },
    "notice": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "superadmins": {
      ".read": "auth != null",
      ".write": false
    },
    "wms_sync": {
      "users": {
        "$uid": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null && auth.uid === $uid"
        }
      },
      "groups": {
        "$gid": {
          ".read": "auth != null && (root.child('superadmins/'+auth.uid).exists() || root.child('userGroup/'+auth.uid).val() === $gid)",
          ".write": "auth != null && (root.child('superadmins/'+auth.uid).exists() || root.child('userGroup/'+auth.uid).val() === $gid)"
        }
      }
    }
  }
}
