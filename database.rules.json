{
  "rules": {
    "warehouses": {
      "$wid": {
        ".read": "auth != null && (root.child('superadmins/'+auth.uid).exists() || root.child('userWarehouse/'+auth.uid).val() === $wid || (root.child('userGroup/'+auth.uid).exists() && root.child('groups/'+root.child('userGroup/'+auth.uid).val()+'/'+$wid).exists()))",
        ".write": "auth != null && (root.child('superadmins/'+auth.uid).exists() || root.child('userWarehouse/'+auth.uid).val() === $wid || (root.child('userGroup/'+auth.uid).exists() && root.child('groups/'+root.child('userGroup/'+auth.uid).val()+'/'+$wid).exists()))",
        "members": {
          "$uid": {
            ".write": "auth != null && auth.uid === $uid"
          }
        }
      }
    },
    "txLogs": {
      "$wid": {
        ".read": "auth != null && (root.child('superadmins/'+auth.uid).exists() || root.child('userWarehouse/'+auth.uid).val() === $wid || (root.child('userGroup/'+auth.uid).exists() && root.child('groups/'+root.child('userGroup/'+auth.uid).val()+'/'+$wid).exists()))",
        ".write": "auth != null && (root.child('superadmins/'+auth.uid).exists() || root.child('userWarehouse/'+auth.uid).val() === $wid || (root.child('userGroup/'+auth.uid).exists() && root.child('groups/'+root.child('userGroup/'+auth.uid).val()+'/'+$wid).exists()))"
      }
    },
    "warehouseIndex": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "userWarehouse": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "userGroup": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && (auth.uid === $uid || root.child('superadmins/'+auth.uid).exists())"
      }
    },
    "groups": {
      ".read": "auth != null && root.child('superadmins/'+auth.uid).exists()",
      "$gid": {
        ".read": "auth != null && (root.child('superadmins/'+auth.uid).exists() || root.child('userGroup/'+auth.uid).val() === $gid)",
        ".write": "auth != null && root.child('superadmins/'+auth.uid).exists()"
      }
    },
    "inviteCodes": {
      ".read": "auth != null",
      "$code": {
        ".write": "auth != null"
      }
    },
    "notices": {
      "$gid": {
        ".read": "auth != null && (root.child('superadmins/'+auth.uid).exists() || root.child('userGroup/'+auth.uid).val() === $gid)",
        ".write": "auth != null && (root.child('superadmins/'+auth.uid).exists() || root.child('userGroup/'+auth.uid).val() === $gid)"
      }
    },
    "notice": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "superadmins": {
      ".read": "auth != null",
      ".write": false
    },
    "pageAccess": {
      ".read": true,
      ".write": "auth != null && root.child('superadmins/'+auth.uid).exists()"
    },
    "vendorConfig": {
      "$gid": {
        ".read": "auth != null && (root.child('superadmins/'+auth.uid).exists() || root.child('userGroup/'+auth.uid).val() === $gid)",
        ".write": "auth != null && root.child('superadmins/'+auth.uid).exists()"
      }
    },
    "vendorByEmail": {
      "$ekey": {
        ".read": "auth != null && (root.child('superadmins/'+auth.uid).exists() || (auth.token.email != null && auth.token.email.toLowerCase().replace('.',',') === $ekey))",
        ".write": "auth != null && root.child('superadmins/'+auth.uid).exists()"
      }
    },
    "vendorStatus": {
      "$gid": {
        ".write": "auth != null && (root.child('superadmins/'+auth.uid).exists() || root.child('userGroup/'+auth.uid).val() === $gid)",
        "$vid": {
          ".read": "auth != null && (root.child('superadmins/'+auth.uid).exists() || root.child('userGroup/'+auth.uid).val() === $gid || (auth.token.email != null && root.child('vendorByEmail/'+auth.token.email.toLowerCase().replace('.',',')+'/gid').val() === $gid && root.child('vendorByEmail/'+auth.token.email.toLowerCase().replace('.',',')+'/vendorId').val() === $vid))"
        }
      }
    },
    "wms_sync": {
      "users": {
        "$uid": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null && auth.uid === $uid"
        }
      },
      "groups": {
        "$gid": {
          ".read": "auth != null && (root.child('superadmins/'+auth.uid).exists() || root.child('userGroup/'+auth.uid).val() === $gid)",
          ".write": "auth != null && (root.child('superadmins/'+auth.uid).exists() || root.child('userGroup/'+auth.uid).val() === $gid)",
          "picktalk": {
            "logs": {
              ".indexOn": ["dateInt"]
            }
          }
        }
      }
    }
  }
}
